# ── LLM API Keys ──────────────────────────────────────────────────────────────
# OpenAI（gpt-4o / gpt-4o-mini）
OPENAI_API_KEY=sk-...

# Anthropic（claude-3.5-sonnet / claude-3-haiku）
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# ── 搜索引擎 ──────────────────────────────────────────────────────────────────
# Tavily Search API（SEO_Researcher 节点使用）
TAVILY_API_KEY=tvly-...

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=seo-agent
LANGCHAIN_API_KEY=ls__...

# ── 运行时配置 ────────────────────────────────────────────────────────────────
# 默认使用的 LLM 提供商（openai / anthropic / google）
DEFAULT_LLM_PROVIDER=openai
# 默认模型名称
DEFAULT_MODEL=gpt-4o-mini
